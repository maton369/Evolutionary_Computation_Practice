#include "Bat.h"

/*
    ============================================================
    Bat.cpp
    ============================================================

    このファイルでは、コウモリアルゴリズム
    (Bat Algorithm, BA)
    における 1 個のコウモリ Bat の具体的な振る舞いを実装している。

    ------------------------------------------------------------
    Bat の理論的な位置づけ
    ------------------------------------------------------------

    BA では、各 Bat は 1 個の候補解である。
    ただし単なる静的な候補解ではなく、

        - 現在位置 pos
        - 速度 velocity
        - 周波数 freq
        - パルス率 pulse
        - 音量 loudness

    を持ちながら、時間とともに探索空間内を移動する
    動的な探索主体として扱われる。

    この点で BA は、

        - 速度を持つという意味では PSO に近い
        - 受理判定や局所探索を持つという意味では
          焼きなましや局所探索法にも近い

    という、複数のメタヒューリスティクス的性質を併せ持つ。

    ------------------------------------------------------------
    このコードでの探索対象
    ------------------------------------------------------------

    これまでの Dataset クラスの設計から考えると、
    pos は

        標準偏回帰係数ベクトル

    を表している。

    つまりこの Bat は、

        「ある回帰係数ベクトルを仮定したとき、
         そのモデルはどれくらい良いか」

    を表す候補解である。

    その良さは evaluate() によって計算される value で測られる。
    この value は文脈上、

        標準化済みデータに対する二乗誤差和

    であり、

        小さいほど良い

    最小化問題だと解釈するのが自然である。

    ------------------------------------------------------------
    Bat::move(t) が担う 3 種類の探索
    ------------------------------------------------------------

    この実装の move(t) を見ると、
    1 回の更新の中で次の 3 種類の探索が組み合わさっている。

    1. bestPos 方向への移動
       - 群れ全体の最良解へ引かれる大域探索

    2. 良い Bat の近傍探索
       - 上位個体の周辺を細かく探る局所探索

    3. 完全ランダムな候補生成
       - 停滞を防ぐための探索多様性確保

    つまりこの Bat 実装は、

        exploit（良い解の近くを詰める）
        と
        explore（新しい領域を試す）

    を 1 個体の中で同時に扱っている。

    ------------------------------------------------------------
    loudness と pulse の意味
    ------------------------------------------------------------

    BA の特徴的なパラメータが

        - loudness
        - pulse

    である。

    loudness:
        新しい候補を受理しやすいかどうかに関わる量。
        一般に探索初期は大きく、後半で小さくなる。

        直感的には
            「大胆さ」
        に対応する。

    pulse:
        局所探索をどれくらい行うかに関わる量。
        一般に時刻とともに上昇する。

        直感的には
            「細かく詰める傾向」
        に対応する。

    したがって BA は、

        初期:
            広く試す
        後半:
            良い場所の近くを慎重に詰める

    という挙動を、これらの内部状態の変化で実現している。
*/


//============================================================
// コンストラクタ
// argPop: 属しているコウモリ群
//============================================================
Bat::Bat(Population* argPop)
{
    int i;

    /*
        この Bat がどの Population に属しているかを保存する。

        Bat 単独では
            - 問題の次元数
            - データセット
            - 群れ全体の bestPos
            - 他個体の状態
        を知らない。

        そのため pop を通して共有情報へアクセスする設計になっている。

        つまり Bat は、
        Population に埋め込まれた探索主体である。
    */
    pop = argPop;

    /*
        現在位置 pos を確保する。

        この問題では pos が標準偏回帰係数ベクトルを表すため、
        次元数は説明変数数 exVarNum に一致する。
    */
    pos = new double[pop->dataset->exVarNum];

    /*
        局所探索候補 1 を保存するための配列。

        newPos1 は
            「良いコウモリの近く」
        に生成される候補解を一時的に保持する。

        これは exploit 寄りの候補であり、
        有望な領域を細かく調べるために使われる。
    */
    newPos1 = new double[pop->dataset->exVarNum];

    /*
        ランダム候補 2 を保存するための配列。

        newPos2 は
            「完全にランダムな新候補」
        を一時的に保持する。

        これは explore 寄りの候補であり、
        局所停滞から抜けるために重要である。
    */
    newPos2 = new double[pop->dataset->exVarNum];

    /*
        速度ベクトルを確保する。

        BA は PSO に似て、
        候補解が位置だけでなく速度も持つ。
        velocity は次時刻の移動量を表す。
    */
    velocity = new double[pop->dataset->exVarNum];

    /*
        初期位置と初期速度を設定する。

        pos は探索範囲 [COEF_MIN, COEF_MAX] の一様乱数で初期化する。
        これにより初期集団は探索空間の複数領域へばらける。

        velocity はここでは 0.0 で初期化している。
        つまり探索開始直後は慣性ではなく、
        bestPos 方向や周波数更新によって動き始める設計である。

        これは初期挙動を安定させる意図として自然である。
    */
    for (i = 0; i < pop->dataset->exVarNum; i++) {
        pos[i] = COEF_MIN + (COEF_MAX - COEF_MIN) * RAND_01;
        velocity[i] = 0.0;
    }

    /*
        初期位置の評価値を計算する。

        ここでの value は、
        現在の回帰係数ベクトル pos に対する二乗誤差和であり、
        小さいほど良い。
    */
    value = evaluate(pos);

    /*
        初期周波数を 0 にする。

        実際の周波数は move(t) の中で時刻ごとに再設定されるため、
        ここではダミー初期値として 0.0 を置いている。
    */
    freq = 0.0;

    /*
        初期パルス率を 0 にする。

        BA では pulse は時間とともに増えることが多いため、
        初期は低く設定して
            大域探索寄り
        に始める設計が自然である。
    */
    pulse = 0.0;

    /*
        初期音量を LOUD_0 に設定する。

        loudness は候補受理の寛容さを表す。
        初期に大きくしておくことで、
        探索初期は比較的大胆に候補を受け入れられる。
    */
    loudness = LOUD_0;
}


//============================================================
// デストラクタ
//============================================================
Bat::~Bat()
{
    /*
        動的確保した配列を解放する。

        Bat は
            - 現在位置
            - 局所探索候補
            - ランダム候補
            - 速度
        を自分で所有しているため、
        その後始末は Bat 自身が行う。
    */
    delete[] pos;
    delete[] newPos1;
    delete[] newPos2;
    delete[] velocity;
}


//============================================================
// コウモリを移動する
// t: 時刻
//============================================================
void Bat::move(int t)
{
    int i, r;
    double newValue1, newValue2, aveLoud;
    double* tmp;

    /*
        この関数は BA の本体である。

        1 回の move(t) の中で、

            1. 群れの最良解方向への移動
            2. 良い個体近傍の局所探索
            3. ランダム候補生成
            4. 候補受理判定
            5. pulse と loudness の更新

        を行う。

        つまり 1 個体の時間発展と、
        探索モードの切り替えを同時に担っている。
    */

    //--------------------------------------------------------
    // 1. 最良コウモリの方向に移動する
    //--------------------------------------------------------

    /*
        周波数 freq をランダムに決める。

        BA では frequency が速度更新に影響し、
        探索の変化幅を制御する。

        FREQ_MIN から FREQ_MAX の間で乱数生成することで、
        個体ごと・時刻ごとに異なる更新幅を持たせている。
    */
    freq = FREQ_MIN + (FREQ_MAX - FREQ_MIN) * RAND_01;

    /*
        bestPos 方向への速度更新と位置更新を行う。

        式:

            velocity[i] += (bestPos[i] - pos[i]) * freq
            pos[i]      += velocity[i]

        これは PSO に似た構造で、
        現在位置から群れ全体の最良位置 bestPos へ向かう方向へ
        動くことを意味する。

        直感的には、
            「良い解の方向へ飛んでいく」
        操作である。

        周波数 freq が大きいほど更新量が大きくなり、
        より荒い移動になる。
    */
    for (i = 0; i < pop->dataset->exVarNum; i++) {
        velocity[i] += (pop->bestPos[i] - pos[i]) * freq;
        pos[i] += velocity[i];
    }

    /*
        更新後の現在位置を評価する。

        ここで value は新しい pos に対応する二乗誤差和となる。
    */
    value = evaluate(pos);

    //--------------------------------------------------------
    // 2. 良いコウモリの近傍に新しい移動先を生成する
    //--------------------------------------------------------

    /*
        RAND_01 > pulse のとき、
        良いコウモリの近傍に局所探索候補 newPos1 を作る。

        pulse は時間とともに上昇するよう設計されることが多く、
        ここではその値によって局所探索を行うかどうかを決めている。

        この if 文の意味は、
            「ある条件で exploit 寄りの候補を作る」
        と読むと分かりやすい。
    */
    if (RAND_01 > pulse) {

        /*
            上位個体群の中から 1 個をランダムに選ぶ。

            POP_SIZE * BEST_RATE 個までを
            「良いコウモリ」とみなしている設計である。

            たとえば BEST_RATE = 0.2 なら、
            上位 20% の個体群から局所探索の基準個体を選ぶ。

            これは bestPos 1 点だけに依存しないため、
            探索が過度に 1 点へ集中するのを防ぎやすい。
        */
        r = rand() % (int)(POP_SIZE * BEST_RATE);

        /*
            群れ全体の平均音量を計算する。

            平均音量を局所探索の揺らぎ幅として使うことで、
            集団全体の探索段階に応じて
            局所探索の歩幅が変わる。

            loudness が大きい初期は大きく探索し、
            loudness が下がる後半では細かく探索する、
            という BA の特徴がここに表れている。
        */
        aveLoud = 0.0;
        for (i = 0; i < POP_SIZE; i++) {
            aveLoud += pop->bat[i]->loudness;
        }
        aveLoud /= POP_SIZE;

        /*
            選ばれた良い個体 pop->bat[r] の近傍に
            newPos1 を生成する。

            式:

                newPos1[i]
                =
                pop->bat[r]->pos[i]
                + noise

            ここで noise は
                [-1, 1] 程度の乱数 × 平均音量
            である。

            つまり newPos1 は、
            上位個体の周囲を平均音量に応じた半径でランダムに探る
            局所探索候補である。
        */
        for (i = 0; i < pop->dataset->exVarNum; i++) {
            newPos1[i] = pop->bat[r]->pos[i]
                       + (rand() / (RAND_MAX / 2.0) - 1) * aveLoud;
        }

        /*
            局所探索候補 newPos1 の評価値を計算する。
        */
        newValue1 = evaluate(newPos1);
    } else {
        /*
            局所探索を行わない場合は、
            比較で必ず負けるように DBL_MAX を入れておく。

            これにより後続の「より良い候補を選ぶ」処理を簡単にしている。
        */
        newValue1 = DBL_MAX;
    }

    //--------------------------------------------------------
    // 3. ランダムに新しい移動先を生成する
    //--------------------------------------------------------

    /*
        完全ランダムな候補 newPos2 を生成する。

        これは explore 寄りの候補であり、
        良い個体周辺だけを見て局所最適に閉じ込められるのを防ぐ。

        探索空間全体から新しい可能性を試す役割を持つ。
    */
    for (i = 0; i < pop->dataset->exVarNum; i++) {
        newPos2[i] = COEF_MIN + (COEF_MAX - COEF_MIN) * RAND_01;
    }

    /*
        ランダム候補 newPos2 の評価値を計算する。
    */
    newValue2 = evaluate(newPos2);

    //--------------------------------------------------------
    // 4. 新しい移動先のほうが良かったら置換し，
    //    パルス率と音量を更新する
    //--------------------------------------------------------

    /*
        候補受理判定を行う。

        条件は

            1. newPos1 または newPos2 が現在位置より良い
            2. RAND_01 < loudness

        の両方である。

        これは BA における
            「良い候補が見つかり、かつその時点の音量に応じて受理する」
        というルールに対応する。

        loudness が大きい初期ほど受理しやすく、
        後半は慎重になる。

        したがってここは、
        単なる greedy 更新ではなく
        探索段階に応じて受理の柔らかさが変わる仕組みになっている。
    */
    if (((newValue1 < value) || (newValue2 < value))
        && (RAND_01 < loudness)) {

        /*
            2 つの候補のうち、より良い方を採用する。

            newValue1 < newValue2 なら局所探索候補を採用し、
            そうでなければランダム候補を採用する。

            実装では pos と候補配列のポインタを交換しているため、
            大きなベクトルコピーを避けられて効率的である。
        */
        if (newValue1 < newValue2) {
            tmp = pos;
            pos = newPos1;
            newPos1 = tmp;
            value = newValue1;
        } else {
            tmp = pos;
            pos = newPos2;
            newPos2 = tmp;
            value = newValue2;
        }

        /*
            パルス率 pulse を更新する。

            式:

                pulse = PULSE_0 * (1 - exp(-PULSE_R * t))

            これは時刻 t が大きくなるほど pulse が増加し、
            最終的に PULSE_0 へ近づく形である。

            直感的には、
                探索後半ほど局所探索を行いやすくなる
            設計である。
        */
        pulse = PULSE_0 * (1 - exp(-PULSE_R * (double)t));

        /*
            音量 loudness を減衰させる。

            式:

                loudness *= LOUD_R

            により、時刻が進むにつれて loudness は小さくなる。

            その結果、
                探索初期は大胆に候補を受理し、
                後半は慎重に収束する
            挙動が生まれる。
        */
        loudness *= LOUD_R;
    }
}


//============================================================
// 評価値を算出する
// argPos: 評価対象のコウモリの位置
// 戻り値: 評価値
//============================================================
double Bat::evaluate(double* argPos)
{
    int i, j;
    double diff, retValue;

    /*
        この関数は、与えられた位置 argPos に対する評価値を返す。

        現在位置 pos ではなく引数 argPos を取っているのは重要である。
        これにより

            - 現在位置 pos
            - 局所探索候補 newPos1
            - ランダム候補 newPos2

        を同じ評価関数で比較できる。

        つまり evaluate(argPos) は、
        候補受理前の比較用評価関数として設計されている。
    */

    /*
        評価値は二乗誤差和なので、最初は 0.0 に初期化する。
    */
    retValue = 0.0;

    /*
        各データ点 i について残差 diff を計算する。

        resSData[i] は標準化済み目的変数であり、
        exSData[i][j] は標準化済み説明変数である。

        argPos[j] を回帰係数とみなすと、
        予測値は

            Σ_j argPos[j] * exSData[i][j]

        となる。

        したがって diff は

            実測値 - 予測値

        に対応する。
    */
    for (i = 0; i < pop->dataset->dataNum; i++) {
        diff = pop->dataset->resSData[i];

        for (j = 0; j < pop->dataset->exVarNum; j++) {
            diff -= argPos[j] * pop->dataset->exSData[i][j];
        }

        /*
            残差の二乗を足し込む。

            最終的な retValue は

                Σ_i (y_i - y_hat_i)^2

            となる。

            これは回帰問題における残差平方和であり、
            小さいほど良いモデルである。
        */
        retValue += pow(diff, 2.0);
    }

    /*
        評価値を返す。

        このコード全体では最小化問題なので、
        retValue が小さいほど良い候補解である。
    */
    return retValue;
}


/*
    ============================================================
    まとめ
    ============================================================

    この Bat.cpp の本質は、
    コウモリアルゴリズムにおける 1 個体を

        候補解
        + 動的状態
        + 局所探索機構
        + 候補受理機構

    を持つ探索主体として実装している点にある。

    - コンストラクタ
      初期位置・初期速度・初期評価・初期内部状態を作る

    - move(t)
      bestPos 方向の大域移動、
      良個体近傍の局所探索、
      ランダム候補探索、
      候補受理、
      pulse / loudness 更新
      をまとめて行う

    - evaluate(argPos)
      与えられた候補位置の回帰誤差を評価する

    つまり Bat は、
    BA の探索力学そのものを担う中心的な個体クラスである。

    Population が群れ全体の秩序と最良解を管理し、
    Bat が個体レベルの更新式を担うことで、
    コウモリアルゴリズム全体が成り立っている。
*/