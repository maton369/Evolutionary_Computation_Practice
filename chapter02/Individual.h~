#ifndef INDIVIDUAL_H
#define INDIVIDUAL_H

/*
    ============================================================
    Individual.h
    ============================================================

    このファイルは、進化計算における「個体 (Individual)」を定義する。

    ここで重要なのは、
    Individual は単なる配列ではなく、
    「探索空間上の1つの候補解」を表す抽象単位だという点である。

    進化計算では、
    解を1つだけ持って直接改善するのではなく、
    複数の候補解を同時に保持し、
    それらを比較・選択・交叉・突然変異させながら探索を進める。

    そのため、Individual は Population の構成要素であり、
    Population が「集団全体の探索戦略」を担うのに対し、
    Individual は「1つの候補解の状態」を担う。

    ------------------------------------------------------------
    この設計で Individual が持つ責務
    ------------------------------------------------------------

    1. 染色体 (chrom) を保持する
       - 染色体は候補解の内部表現である。
       - 問題によっては 0/1, 整数列, 実数ベクトル, 順列などになる。
       - 今回は int chrom[N] として定義されているため、
         各遺伝子座が整数値を持つ離散表現を想定している。

    2. 適応度 (fitness) を保持する
       - 適応度は、その個体がどれだけ良い解かを数値化したもの。
       - Population 側はこの fitness を使って個体同士を比較する。
       - つまり、個体評価の結果は個体自身に保存され、
         集団選択はその値に依存して行われる。

    3. 自分自身を生成・変換する操作を持つ
       - evaluate()  : 自分の適応度を計算する
       - crossover() : 2つの親から子へ内容を作り替える
       - mutate()    : 自分の遺伝子を局所的に変更する

    ------------------------------------------------------------
    設計上のポイント
    ------------------------------------------------------------

    この段階では、アルゴリズムの詳細実装よりも、
    クラス間の責務分担を明確にすることが重要である。

    - Individual は「1個体の表現と変換」
    - Population は「個体群全体の管理と世代交代」

    という分離になっている。

    この分離により、
    問題ごとに Individual の評価関数だけ差し替えたり、
    Population の選択戦略だけ変更したりしやすくなる。

    つまりこの設計は、
    進化計算の典型的な構成要素
        表現 (representation)
        評価 (evaluation)
        選択 (selection)
        交叉 (crossover)
        突然変異 (mutation)
        世代交代 (replacement)
    のうち、
    「表現・評価・個体変換」を Individual 側に寄せた設計である。

    ------------------------------------------------------------
    pass 相当について
    ------------------------------------------------------------

    C++ には Python の pass のような構文は存在しない。
    そのため、未実装の関数は

        - 宣言だけを書く
        - 実装側で TODO コメントを置いて空実装にする

    という形で表現する。

    今回は「全体設計の理解」が主目的なので、
    実装の中身はまだ入れず、コメントで役割を明確にしている。
*/

#include <ctime>
#include <cstdlib>
#include <climits>
#include <cfloat>
#include <cmath>

/*
    ============================================================
    定数定義
    ============================================================

    GEN_MAX:
        世代交代を何回行うかを表す。
        進化計算では、世代数が増えるほど探索機会は増えるが、
        計算時間も増える。

    POP_SIZE:
        個体群サイズ。
        同時に何個の候補解を保持するかを決める。
        個体群が大きいほど多様性は高まりやすいが、
        評価コストも増える。

    ELITE:
        エリート保存でそのまま次世代へコピーする個体数。
        最良個体の破壊を防ぎ、性能の単調悪化を起こしにくくする。

    MUTATE_PROB:
        突然変異確率。
        探索空間の局所改善だけでなく、新しい構造の発見にも寄与する。

    N:
        染色体長。
        コメント上は「集合の要素となる最大数の平方値」とあるため、
        おそらく探索対象の問題構造から導かれる固定長である。
        ここでは「1個体が持つ遺伝子数」と理解すればよい。

    RAND_01:
        0以上1以下の一様乱数。
        交叉・突然変異など確率的操作の基礎になる。
*/
#define GEN_MAX 1000
#define POP_SIZE 1000
#define ELITE 1
#define MUTATE_PROB 0.01
#define N 64
#define RAND_01 ((double) rand() / RAND_MAX)

class Individual {
public:
    /*
        --------------------------------------------------------
        コンストラクタ / デストラクタ
        --------------------------------------------------------

        コンストラクタでは通常、
        染色体の初期化を行う。
        典型的にはランダム初期化であり、
        個体群の初期多様性を作る起点となる。

        デストラクタは、Individual が内部で動的確保を行う場合に重要になる。
        現在の設計では chrom は固定長配列であり、
        基本的には特別な解放処理は不要である。
        ただし、将来設計を拡張して補助領域を持つ場合に備えて、
        宣言しておくことには意味がある。
    */
    Individual();
    ~Individual();

    /*
        --------------------------------------------------------
        evaluate()
        --------------------------------------------------------

        この個体の適応度を計算する。

        理論的には、
        適応度関数は探索空間に「良し悪しの地形」を与える。
        進化計算は、その地形の高い方向を集団的に登っていく
        ヒューリスティック探索とみなせる。

        Population 側はこの結果を用いて個体を比較・ソート・選択するため、
        evaluate() は Individual と Population を接続する最重要関数の1つである。

        今回はまだ設計段階なので、実装は cpp 側で空にしておく。
    */
    void evaluate();

    /*
        --------------------------------------------------------
        crossover(Individual* p1, Individual* p2)
        --------------------------------------------------------

        2つの親個体 p1, p2 をもとに、
        この個体を「子個体」として構成する。

        つまり、このメソッドは
        「this を子として上書きする」設計になっている。

        進化計算では交叉により、
        複数の親に分散して存在していた有用な部分構造を
        1つの子へ再結合できる可能性がある。

        これは building block hypothesis の文脈でも重要であり、
        進化計算が単なるランダム探索ではなく、
        良い部分解の組み合わせを活用できる理由の1つである。

        今回は設計段階なので、実装は cpp 側で空にしておく。
    */
    void crossover(Individual* p1, Individual* p2);

    /*
        --------------------------------------------------------
        mutate()
        --------------------------------------------------------

        この個体に突然変異を起こす。

        突然変異は、探索の多様性を維持し、
        集団全体が同質化しすぎることを防ぐ役割を持つ。

        交叉が既存の個体情報の再結合だとすれば、
        突然変異は新規情報の注入に近い。

        局所最適への早すぎる収束を防ぐためにも重要である。

        今回は設計段階なので、実装は cpp 側で空にしておく。
    */
    void mutate();

    /*
        --------------------------------------------------------
        データメンバ
        --------------------------------------------------------
    */

    /*
        chrom:
            染色体。
            個体が表現する候補解そのもの。

            ここでは長さ N の整数配列になっている。
            各要素が何を意味するかは問題依存である。

            たとえば、
            - 0/1 の選択状態
            - 順列を構成する要素
            - 離散パラメータ
            - グリッド配置
            など、さまざまな解釈が可能である。

            進化計算においては、
            この表現の選び方がアルゴリズム性能に大きく影響する。
            つまり、chrom は単なる配列ではなく、
            「探索空間をどのように座標化するか」という設計そのものである。
    */
    int chrom[N];

    /*
        fitness:
            適応度。
            Population はこの値をもとに個体の優劣を判断する。

            よって fitness は、
            「個体単体の評価結果」であると同時に、
            「集団内競争の基準」でもある。
    */
    double fitness;
};

#endif
